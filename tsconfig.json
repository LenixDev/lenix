{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"strict": true,
		"declaration": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"paths": {
			"~/*": ["./*"]
		},
		"types": ["node"]
	},
	"include": ["*.ts", "modules/**/*", "format/*.ts"]
}
